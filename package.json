{
  "name": "cppkg-cli",
  "version": "1.0.1",
  "description": "CLI for downloading C/C++ packages into a shared include directory or project workspace",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "cppkg-cli": "./dist/main.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "docs": "tsx ./scripts/docs.ts",
    "docs:generate": "tsx ./scripts/generate-docs.ts",
    "docs:site:build": "vite build --config vite.docs.config.mjs",
    "docs:site:dev": "vite --config vite.docs.config.mjs",
    "docs:site:preview": "vite preview --config vite.docs.config.mjs",
    "dev": "node --import=tsx ./src/main.ts",
    "prepack": "npm test",
    "pretest": "npm run build",
    "test": "npm run test:typecheck && vitest run",
    "test:typecheck": "tsc -p tsconfig.test.json && tsc -p tsconfig.scripts.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeremyYu-cn/cppkg-cli.git"
  },
  "keywords": [
    "c++",
    "cli",
    "cpp",
    "header-only",
    "package",
    "management"
  ],
  "author": "Jeremy Yu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JeremyYu-cn/cppkg-cli/issues"
  },
  "homepage": "https://jeremyyu-cn.github.io/cppkg-cli/",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "commander": "^14.0.3",
    "http-proxy-agent": "^9.0.0",
    "https-proxy-agent": "^9.0.0",
    "picocolors": "^1.1.1",
    "typescript": "^6.0.3",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^6.0.1",
    "github-markdown-css": "^5.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.21.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
